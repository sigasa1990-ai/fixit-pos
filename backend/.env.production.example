# FIXIT POS — Production Environment Variables
# COPY THIS FILE TO .env AND FILL IN ALL VALUES

APP_NAME="FIXIT POS API"
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://fixit:CHANGE_ME@postgres:5432/fixit_pos
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# JWT
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PIN_MIN_LENGTH=4
PIN_MAX_LENGTH=8

# CORS
CORS_ORIGINS=["https://app.fixitpos.com"]

# Sentry (optional)
SENTRY_DSN=

# Logging
LOG_LEVEL=INFO
