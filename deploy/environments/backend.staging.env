# FIXIT POS — Backend Staging Environment
# cp to .env on staging server
# Domain: staging-pos.fixitsoluciones.com

APP_NAME="FIXIT POS API (STAGING)"
APP_VERSION=1.0.0
DEBUG=true

# Database (staging PostgreSQL)
DATABASE_URL=postgresql+asyncpg://fixit:STAGING_PASSWORD@staging-db:5432/fixit_pos_staging
DATABASE_ECHO=true
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# JWT
JWT_SECRET_KEY=CHANGE_ME_STAGING_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Security (lower for testing)
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=10
LOGIN_LOCKOUT_MINUTES=5

# CORS — Include staging + localhost for testing
CORS_ORIGINS=["https://staging-pos.fixitsoluciones.com","http://localhost:3000"]

# Logging
LOG_LEVEL=DEBUG
