# FIXIT POS — Backend Production Environment
# cp to .env on production server
# Domain: api-pos.fixitsoluciones.com

APP_NAME="FIXIT POS API"
APP_VERSION=1.0.0
DEBUG=false

# Database (Render PostgreSQL)
DATABASE_URL=postgresql+asyncpg://fixit:PROD_PASSWORD@fixit-pos-db.internal:5432/fixit_pos
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# JWT — GENERATE WITH: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_64_HEX_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PIN_MIN_LENGTH=4
PIN_MAX_LENGTH=8

# CORS — Only authorized POS domains
CORS_ORIGINS=["https://pos.fixitsoluciones.com","https://staging-pos.fixitsoluciones.com"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=10

# Logging
LOG_LEVEL=INFO

# Sentry (optional — uncomment and configure)
# SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx
